{
  "permissions": {
    "allow": [
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(jq -e '.hooks.Stop[] | .hooks[] | select\\(.type == \"\"command\"\"\\) | .command' /Users/1234/animal-rescue/.claude/settings.json)",
      "Read(//Users/1234/.claude/**)",
      "Bash(git push:*)"
    ]
  },
  "enabledMcpjsonServers": [
    "netlify"
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/1234/animal-rescue && git add -A && git diff --cached --quiet || (git commit -m \"chore: auto-save $(date '+%Y-%m-%d %H:%M')\" && git push) 2>/dev/null || true",
            "statusMessage": "Pushing changes to GitHub..."
          }
        ]
      }
    ]
  }
}
